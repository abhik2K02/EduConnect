# ============================================================
#  Lecture Assistant — Root .gitignore
# ============================================================

# ── Sensitive / secrets ──────────────────────────────────────
.env
.env.*
!.env.example
backend/serviceAccountKey.json
**/serviceAccountKey.json

# ── Dependencies ─────────────────────────────────────────────
node_modules/
**/node_modules/

# ── Build outputs ────────────────────────────────────────────
dist/
dist-ssr/
dist-electron/
**/dist/
build/

# ── Logs ─────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Lock files (optional — keep if you want reproducible installs) ─
# package-lock.json
# yarn.lock

# ── Packaged / archive files ──────────────────────────────────
*.zip
*.tar.gz
*.rar
*.7z

# ── Temporary / generated export files ───────────────────────
project_code_export.md
all_code.txt
all_code_export.txt
*.local

# ── OS generated ──────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor / IDE ──────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Electron ──────────────────────────────────────────────────
dist-electron/
release/
out/

# ── Misc ──────────────────────────────────────────────────────
*.pem
*.key
